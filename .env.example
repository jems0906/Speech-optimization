# Model settings
MODEL_NAME=whisper-base
MODEL_TYPE=whisper
DEVICE=cuda
USE_FP16=true

# Optimization
USE_QUANTIZATION=false
USE_TENSORRT=false
TENSORRT_ENGINE_PATH=

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=false

# Audio
SAMPLE_RATE=16000
MAX_AUDIO_LENGTH_SECONDS=30.0

# Profiling
ENABLE_PROFILING=false
